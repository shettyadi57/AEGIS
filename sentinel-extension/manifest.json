{
  "manifest_version": 3,
  "name": "AEGIS Sentinel",
  "version": "1.0.0",
  "description": "Advanced Exam Guardrail Integrity System — Sentinel Monitor",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "notifications",
    "alarms",
    "clipboardRead"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/sentinel.js",
        "camera/faceMonitor.js",
        "audio/voiceMonitor.js",
        "utils/eventLogger.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
